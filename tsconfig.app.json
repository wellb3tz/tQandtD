{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "rootDir": ".",
    "outDir": "./dist-app",
    "types": ["vite/client"],
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": [
    "src/**/*",
    "app/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-app",
    "**/*.test.ts"
  ]
}
