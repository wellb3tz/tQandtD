{
  "name": "procedural-world-engine",
  "version": "1.0.0",
  "description": "A TypeScript-based procedural world generation engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "require": "./dist/worker.js",
      "default": "./dist/worker.js"
    }
  },
  "scripts": {
    "clean": "node scripts/clean.js",
    "build": "npm run clean -- dist && tsc",
    "build:demo": "vite build",
    "build:analyze": "vite build --mode analyze",
    "build:verify": "node scripts/verify-build.js",
    "prepack": "npm run build && npm run build:verify",
    "verify": "npm run build && npm run build:verify && npm run typecheck && npm run typecheck:demo && npm test",
    "verify:release": "npm run verify && npm run build:demo && npm run test:e2e",
    "typecheck": "tsc --noEmit",
    "typecheck:demo": "tsc -p tsconfig.demo.json --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:bench": "vitest run tests/performance.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo": "vite"
  },
  "keywords": [
    "procedural-generation",
    "world-generation",
    "terrain",
    "noise",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.10.0",
    "@types/pako": "^2.0.4",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^1.0.0",
    "fast-check": "^3.15.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.2",
    "terser": "^5.46.1",
    "three": "^0.160.1",
    "typescript": "^5.3.0",
    "vite": "^5.4.21",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "pako": "^2.1.0"
  }
}
