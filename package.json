{
  "name": "procedural-world-engine",
  "version": "1.0.0",
  "description": "A TypeScript-based procedural world generation engine",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "docs/*.md",
    "examples",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "require": "./dist/worker.js",
      "default": "./dist/worker.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "require": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "require": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./rendering": {
      "types": "./dist/rendering/index.d.ts",
      "require": "./dist/rendering/index.js",
      "default": "./dist/rendering/index.js"
    },
    "./adapters/three": {
      "types": "./dist/adapters/three/index.d.ts",
      "require": "./dist/adapters/three/index.js",
      "default": "./dist/adapters/three/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "scripts": {
    "clean": "node scripts/clean.js",
    "build": "npm run clean -- dist && tsc",
    "build:app": "vite build",
    "build:analyze": "vite build --mode analyze",
    "build:verify": "node scripts/verify-build.js",
    "verify:package": "node scripts/verify-package.js",
    "prepack": "npm run build && npm run build:verify && npm run verify:package",
    "verify": "npm run build && npm run build:verify && npm run typecheck && npm run typecheck:app && npm test",
    "verify:release": "npm run verify && npm run build:app && npm run verify:package",
    "typecheck": "tsc --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:bench": "vitest run tests/performance.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "app": "vite"
  },
  "keywords": [
    "procedural-generation",
    "world-generation",
    "terrain",
    "noise",
    "chunk-streaming",
    "threejs",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.10.0",
    "@types/pako": "^2.0.4",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^1.0.0",
    "fast-check": "^3.15.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.2",
    "terser": "^5.46.1",
    "three": "^0.160.1",
    "typescript": "^5.3.0",
    "vite": "^5.4.21",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "three": ">=0.160.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "dependencies": {
    "pako": "^2.1.0"
  }
}
